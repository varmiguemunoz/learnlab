# --- SMTP (salida) ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=usuario@example.com
SMTP_PASS=tu_password_smtp
SMTP_FROM=alertas@example.com

# Múltiples destinatarios separados por coma
ALERT_RECIPIENTS=destino1@example.com,destino2@example.com

# Múltiples keywords separadas por coma
KEYWORDS=DAVIVIENDA

# Intervalo de polling en segundos
POLL_INTERVAL=60

# Base local de la app Mensajes de macOS
MESSAGES_DB=$HOME/Library/Messages/chat.db

# Notificaciones de escritorio en macOS si falla el envío SMTP
DESKTOP_NOTIFICATIONS=true

# Opcionales
# MESSAGES_STATE_FILE=/ruta/absoluta/last_message_rowid.txt
# LOG_FILE=/ruta/absoluta/messages_monitor.log
# LOCK_DIR=/ruta/absoluta/.messages_monitor.lock
